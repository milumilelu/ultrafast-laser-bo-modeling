{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExperienceMemoryUpdateOutput",
  "type": "object",
  "properties": {
    "experience_candidate": {
      "type": "object",
      "properties": {
        "claim": {"type": "string"},
        "evidence": {"type": "object"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "status": {"type": "string"},
        "required_validation": {"type": "array", "items": {"type": "string"}}
      },
      "required": ["claim", "evidence", "confidence", "status", "required_validation"]
    },
    "promotion_recommendation": {
      "type": "object",
      "properties": {
        "should_promote": {"type": "boolean"},
        "reason": {"type": "string"}
      },
      "required": ["should_promote", "reason"]
    }
  },
  "required": ["experience_candidate", "promotion_recommendation"],
  "additionalProperties": false
}
