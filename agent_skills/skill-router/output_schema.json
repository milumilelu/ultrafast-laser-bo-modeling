{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SkillRouterOutput",
  "type": "object",
  "properties": {
    "selected_skill": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "reason": {"type": "string"},
    "required_next_action": {"type": "string"},
    "follow_up_skills": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "required": ["selected_skill", "confidence", "reason", "required_next_action"],
  "additionalProperties": false
}
